#!/usr/bin/env govnovoz
== Проверка ввода и обработка ошибок ==
замутим ввести_число(подсказка):
    логика успех загрузили нет
    слово ввод загрузили ""
    
    крутим не_ успех:
        высер подсказка
        засрать ввод
        
        запахло:
            цифра результат загрузили ввод
            успех загрузили да
            высрать результат
        проветрили:
            высер "❌ Это не число! Попробуй ещё."
            дальше

погнали
    высер "=== ВАЛИДАЦИЯ ВВОДА ==="
    
    цифра возраст загрузили ввести_число("Сколько тебе лет?")
    цифра рост загрузили ввести_число("Какой у тебя рост (в см)?")
    цифра вес загрузили ввести_число("Сколько ты весишь (в кг)?")
    
    высер ""
    высер "=== ТВОИ ДАННЫЕ ==="
    высер "Возраст: " + возраст + " лет"
    высер "Рост: " + рост + " см"
    высер "Вес: " + вес + " кг"
    
    дробное имт загрузили вес разделить ((рост разделить 100) степень 2)
    высер "Индекс массы тела: " + имт
    
    если имт < 18.5:
        высер "⚠️ Недостаточный вес"
    илиесли имт < 25:
        высер "✅ Нормальный вес"
    илиесли имт < 30:
        высер "⚠️ Избыточный вес"
    тогда:
        высер "❌ Ожирение"
закончили
