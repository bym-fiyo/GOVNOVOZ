#!/usr/bin/env govnovoz
== Это файл с расширением .navoz ==
== Навоз — он удобряет код ==

погнали
    высер "🌾 ПРИВЕТ ИЗ НАВОЗА!"
    высер "Это файл с расширением .navoz"
    высер "Он работает точно так же, как .govno"
    высер "Просто пахнет иначе"
    
    высер ""
    высер "Введи своё имя:"
    засрать имя
    высер "Привет, " + имя + "! Ты выбрал навоз."
закончили
